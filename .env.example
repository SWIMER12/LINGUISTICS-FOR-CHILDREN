# Пример переменных окружения. Реальные значения задавайте в окружении
# (shell / systemd / команда запуска gunicorn) — приложение читает их из os.environ.
# Этот файл — только справка; настоящий .env в git не попадает (см. .gitignore).

# Секретный ключ сессий. В проде — длинная случайная строка.
# Сгенерировать: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=замените-на-длинный-случайный-ключ

# Кука сессии только по HTTPS (включать на проде).
SESSION_COOKIE_SECURE=1

# Необязательные (значения по умолчанию безопасны):
# FLASK_DEBUG=0          # отладчик; в проде НИКОГДА не включать
# HOST=127.0.0.1         # 0.0.0.0 — доступ из сети
# PORT=5000
